---
import Layout from '../layouts/Layout.astro';
---

<Layout>

<!-- ══════════════════════════════════════════════
     NAV
══════════════════════════════════════════════ -->
<nav style="position:fixed;top:0;left:0;right:0;z-index:100;backdrop-filter:blur(14px);-webkit-backdrop-filter:blur(14px);background:rgba(19,42,19,0.92);border-bottom:1px solid rgba(144,169,85,0.2);padding:0 1.5rem;">
  <div class="wrap" style="display:flex;align-items:center;justify-content:space-between;height:64px;max-width:1040px;margin:0 auto;width:100%;">
    
    <!-- Logo en Navbar -->
    <a href="/" style="display: flex; align-items: center; text-decoration: none;">
      <img src="/logo.png" alt="hi-POS Logo" style="height: 36px; width: auto;" />
    </a>

    <a href="#demo" class="btn btn-primary btn-sm">Quiero mi demo</a>
  </div>
</nav>


<!-- ══════════════════════════════════════════════
     HERO
══════════════════════════════════════════════ -->
<section class="grid-bg" style="position:relative;min-height:100vh;background-color:#132A13;display:flex;align-items:center;padding:64px 1.5rem 0 1.5rem;overflow:hidden;">

  <!-- Glow -->
  <div style="position:absolute;inset:0;pointer-events:none;background:radial-gradient(ellipse 65% 55% at 72% 50%, rgba(252,163,17,0.07) 0%, transparent 68%);"></div>

  <div class="wrap" style="position:relative;z-index:2;padding-top:5rem;padding-bottom:6rem;width:100%;max-width:1040px;margin:0 auto;">

    <!-- Tag -->
    <div class="fu1" style="display:inline-flex;align-items:center;gap:.6rem;border:1px solid rgba(144,169,85,.35);padding:.45rem 1rem;border-radius:3px;margin-bottom:2.25rem;">
      <span class="pulse-dot" style="width:8px;height:8px;border-radius:50%;background:#90A955;display:inline-block;flex-shrink:0;"></span>
      <span style="font-family:'IBM Plex Mono',monospace;font-size:.68rem;letter-spacing:.1em;text-transform:uppercase;color:#90A955;">Sistema POS · Offline-First · Licencia Perpetua</span>
    </div>

    <!-- Headline (Con espaciado vertical reducido) -->
    <h1 class="fu2" style="font-size:clamp(3rem,7vw,5.5rem);color:#F8F3B9;margin-top:0.2em;margin-bottom:0.4em;line-height:1.1;max-width:700px;">
      Tu restaurante<br/>
      no debería de<br/>
      depender de<br/>
      <span style="color:#FCA311;position:relative;">internet<span style="position:absolute;bottom:4px;left:0;right:0;height:3px;background:#FCA311;opacity:.35;border-radius:2px;"></span></span> para<br/>
      cobrar
    </h1>

    <!-- Sub -->
    <p class="fu3" style="font-size:1.1rem;color:rgba(248,243,185,.72);max-width:500px;margin-bottom:2.5rem;line-height:1.75;">
      hi-POS funciona aunque se caiga el wifi, aunque se vaya la luz del router,
      aunque tu proveedor "tenga mantenimiento". Sin rentas mensuales. Sin sorpresas.
      <strong style="color:rgba(248,243,185,.95);font-weight:500;">Tuyo para siempre.</strong>
    </p>

    <!-- CTAs -->
    <div class="fu4" style="display:flex;flex-wrap:wrap;gap:.875rem;margin-bottom:2.75rem;">
      <a href="#demo" class="btn btn-primary">Quiero ver la demo</a>
      <a href="#como-funciona" class="btn btn-secondary">¿Cómo funciona?</a>
    </div>

    <!-- Badge -->
    <div class="fu5" style="display:inline-flex;align-items:center;gap:.6rem;background:rgba(144,169,85,.1);border:1px solid rgba(144,169,85,.25);padding:.5rem 1.1rem;border-radius:3px;">
      <span style="font-family:'IBM Plex Mono',monospace;font-size:.72rem;color:#90A955;">Funciona sin internet. Siempre.</span>
    </div>

  </div>

  <!-- Bottom line -->
  <div style="position:absolute;bottom:0;left:50%;transform:translateX(-50%);width:1px;height:72px;background:linear-gradient(to bottom, transparent, rgba(144,169,85,.5));"></div>
</section>


<!-- ══════════════════════════════════════════════
     PAIN
══════════════════════════════════════════════ -->
<section style="position:relative;background:#1e3d1e;padding:7rem 1.5rem;">
  <div class="divider-top"></div>
  <div class="wrap" style="max-width:1040px;margin:0 auto;width:100%;">

    <h2 style="font-size:clamp(1.9rem,4vw,3rem);color:#F8F3B9;margin-bottom:3rem;max-width:500px;">
      ¿Cuánto llevas pagando<br/>
      por un sistema que no<br/>
      te pertenece?
    </h2>

    <div class="pain-grid" style="margin-bottom:3rem;">
      {[
        'Pagas cada mes aunque no vendas nada',
        'Si no hay internet, no hay ventas — literal',
        'Para cancelar una comanda necesitas llamar a soporte',
        'Tus datos están en servidores de alguien más',
        'El precio sube y tú no puedes hacer nada',
      ].map(text => (
        <div style="display:flex;align-items:flex-start;gap:1rem;background:rgba(19,42,19,.55);border:1px solid rgba(252,163,17,.12);border-left:3px solid #FCA311;border-radius:5px;padding:1.1rem 1.4rem;margin-bottom:0.75rem;">
          <span style="font-family:'IBM Plex Mono',monospace;font-weight:600;color:#FCA311;font-size:1.1rem;line-height:1;flex-shrink:0;margin-top:2px;">✕</span>
          <p style="color:rgba(248,243,185,.75);font-size:.9rem;line-height:1.55;">{text}</p>
        </div>
      ))}
    </div>

    <div style="background:rgba(252,163,17,.05);border:1px solid rgba(252,163,17,.2);border-radius:8px;padding:1.75rem 2rem;max-width:640px;">
      <p style="color:rgba(248,243,185,.6);font-size:1rem;margin-bottom:.5rem;">Los SaaS de POS están diseñados para que dependas de ellos.</p>
      <p style="font-family:'IBM Plex Mono',monospace;font-weight:600;color:#F8F3B9;font-size:1.05rem;">hi-POS está diseñado para que seas libre.</p>
    </div>

  </div>
</section>


<!-- ══════════════════════════════════════════════
     WHAT IS
══════════════════════════════════════════════ -->
<section style="background:#132A13;padding:8rem 1.5rem;" id="como-funciona">
  <div class="wrap" style="max-width:1040px;margin:0 auto;width:100%;">
    <div style="max-width:640px;">
      <p style="font-family:'IBM Plex Mono',monospace;font-size:.68rem;letter-spacing:.12em;text-transform:uppercase;color:#90A955;margin-bottom:1.5rem;opacity:.8;">¿Que es Hi-POS?</p>
      <h2 style="font-size:clamp(2.2rem,5vw,4rem);color:#F8F3B9;margin-bottom:1.5rem;">
        Un POS completo.<br/>
        Una sola vez.<br/>
        <span style="color:#FCA311;">Sin rentas.</span>
      </h2>
      <p style="font-size:1.05rem;color:rgba(248,243,185,.65);line-height:1.8;max-width:520px;">
        hi-POS es el sistema punto de venta para restaurantes y pizzerías que vive en tu
        máquina, no en la nube de alguien más. Pagas una licencia, lo instalas y es tuyo para
        siempre.
      </p>
    </div>
  </div>
</section>


<!-- ══════════════════════════════════════════════
     FEATURES
══════════════════════════════════════════════ -->
<section style="background:#132A13;padding:0 1.5rem 8rem 1.5rem;">
  <div class="wrap" style="max-width:1040px;margin:0 auto;width:100%;">
    <h2 style="font-size:clamp(1.8rem,4vw,2.8rem);color:#F8F3B9;margin-bottom:2.75rem;">
      Las 6 razones por las<br/>que cambia todo
    </h2>

    <div class="features-grid">

      <!-- Highlight -->
      <div class="fcard fcard-amber" style="background:#1e3d1e;border:1px solid rgba(252,163,17,.25);border-radius:8px;padding:1.75rem 1.6rem;position:relative;">
        <div style="color:#FCA311;margin-bottom:1.25rem;">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="1" y1="1" x2="23" y2="23"/>
            <path d="M16.72 11.06A10.94 10.94 0 0 1 19 12.55"/><path d="M5 12.55a10.94 10.94 0 0 1 5.17-2.39"/>
            <path d="M10.71 5.05A16 16 0 0 1 22.56 9"/><path d="M1.42 9a15.91 15.91 0 0 1 4.7-2.88"/>
            <path d="M8.53 16.11a6 6 0 0 1 6.95 0"/><line x1="12" y1="20" x2="12.01" y2="20"/>
          </svg>
        </div>
        <h3 style="font-size:1rem;color:#F8F3B9;margin-bottom:.45rem;">Offline-First</h3>
        <p style="font-size:.875rem;color:rgba(248,243,185,.55);line-height:1.6;">Funciona sin internet. Siempre. Sin excusas.</p>
        <span style="position:absolute;top:1rem;right:1rem;font-family:'IBM Plex Mono',monospace;font-size:.62rem;font-weight:600;color:#FCA311;background:rgba(252,163,17,.12);padding:.2rem .5rem;border-radius:2px;letter-spacing:.06em;text-transform:uppercase;">Core</span>
      </div>

      <!-- Licencia perpetua -->
      <div class="fcard" style="background:#1e3d1e;border:1px solid rgba(144,169,85,.15);border-radius:8px;padding:1.75rem 1.6rem;">
        <div style="color:#90A955;margin-bottom:1.25rem;">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/>
          </svg>
        </div>
        <h3 style="font-size:1rem;color:#F8F3B9;margin-bottom:.45rem;">Licencia perpetua</h3>
        <p style="font-size:.875rem;color:rgba(248,243,185,.55);line-height:1.6;">Lo compras una vez y es tuyo para siempre.</p>
      </div>

      <!-- Restaurantes -->
      <div class="fcard" style="background:#1e3d1e;border:1px solid rgba(144,169,85,.15);border-radius:8px;padding:1.75rem 1.6rem;">
        <div style="color:#90A955;margin-bottom:1.25rem;">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M3 11l19-9-9 19-2-8-8-2z"/>
          </svg>
        </div>
        <h3 style="font-size:1rem;color:#F8F3B9;margin-bottom:.45rem;">Hecho para restaurantes</h3>
        <p style="font-size:.875rem;color:rgba(248,243,185,.55);line-height:1.6;">Mesas, comandas, cocina y corte de caja.</p>
      </div>

      <!-- Inventario -->
      <div class="fcard" style="background:#1e3d1e;border:1px solid rgba(144,169,85,.15);border-radius:8px;padding:1.75rem 1.6rem;">
        <div style="color:#90A955;margin-bottom:1.25rem;">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
            <rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>
          </svg>
        </div>
        <h3 style="font-size:1rem;color:#F8F3B9;margin-bottom:.45rem;">Inventario inteligente</h3>
        <p style="font-size:.875rem;color:rgba(248,243,185,.55);line-height:1.6;">Descuenta materia prima automáticamente al vender.</p>
      </div>

      <!-- Reportes -->
      <div class="fcard" style="background:#1e3d1e;border:1px solid rgba(144,169,85,.15);border-radius:8px;padding:1.75rem 1.6rem;">
        <div style="color:#90A955;margin-bottom:1.25rem;">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
            <line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/>
          </svg>
        </div>
        <h3 style="font-size:1rem;color:#F8F3B9;margin-bottom:.45rem;">Reportes y corte</h3>
        <p style="font-size:.875rem;color:rgba(248,243,185,.55);line-height:1.6;">Corte de caja diario y exportación a Excel.</p>
      </div>

      <!-- Acceso -->
      <div class="fcard" style="background:#1e3d1e;border:1px solid rgba(144,169,85,.15);border-radius:8px;padding:1.75rem 1.6rem;">
        <div style="color:#90A955;margin-bottom:1.25rem;">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="11" width="18" height="11" rx="2"/>
            <path d="M7 11V7a5 5 0 0110 0v4"/>
          </svg>
        </div>
        <h3 style="font-size:1rem;color:#F8F3B9;margin-bottom:.45rem;">Control de acceso</h3>
        <p style="font-size:.875rem;color:rgba(248,243,185,.55);line-height:1.6;">Roles, PIN y permisos por usuario.</p>
      </div>

    </div>
  </div>
</section>


<!-- ══════════════════════════════════════════════
     COMPARE
══════════════════════════════════════════════ -->
<section style="position:relative;background:#1e3d1e;padding:7rem 1.5rem;">
  <div class="divider-top"></div>
  <div class="wrap" style="max-width:1040px;margin:0 auto;width:100%;">

    <h2 style="font-size:clamp(1.8rem,4vw,2.8rem);color:#F8F3B9;margin-bottom:1rem;">
      Haz las cuentas, el resultado<br/>te va a sorprender
    </h2>
    <p style="color:rgba(248,243,185,.55);font-size:.975rem;margin-bottom:2.75rem;max-width:500px;">
      En 12 meses ya pagaste más de lo que cuesta hi-POS. Y sigues sin ser dueño de nada.
    </p>

    <div style="overflow-x:auto;border-radius:8px;border:1px solid rgba(144,169,85,.2);">
      <table style="width:100%;min-width:520px;border-collapse:collapse;font-size:.9rem;">
        <thead>
          <tr>
            <th style="text-align:left;padding:1rem 1.5rem;font-family:'IBM Plex Mono',monospace;font-size:.68rem;letter-spacing:.08em;text-transform:uppercase;color:rgba(248,243,185,.4);background:rgba(19,42,19,.75);width:38%;font-weight:600;">Característica</th>
            <th style="text-align:left;padding:1rem 1.5rem;font-family:'IBM Plex Mono',monospace;font-size:.68rem;letter-spacing:.08em;text-transform:uppercase;color:rgba(248,243,185,.35);background:rgba(19,42,19,.75);width:31%;font-weight:600;">SaaS típico</th>
            <th style="text-align:left;padding:1rem 1.5rem;font-family:'IBM Plex Mono',monospace;font-size:.68rem;letter-spacing:.08em;text-transform:uppercase;color:#FCA311;background:rgba(252,163,17,.08);width:31%;font-weight:600;">
              hi-POS <span style="display:inline-flex;align-items:center;justify-content:center;width:16px;height:16px;background:#FCA311;color:#132A13;border-radius:50%;font-size:.6rem;font-weight:700;margin-left:.35rem;vertical-align:middle;">✓</span>
            </th>
          </tr>
        </thead>
        <tbody>
          {[
            ['Pago mensual',        '$600–$1,500 MXN/mes',       '$0 — Único pago'],
            ['Disponibilidad',      'Siempre necesitas internet', '✓ Siempre'],
            ['Tus datos son tuyos', '✕ Depende',                 '✓ 100%'],
            ['Licencia perpetua',   '✕',                         '✓'],
            ['Soporte incluido',    '✕ Depende',                 '✓ Incluido'],
            ['Se instala en tu PC', '✕',                         '✓'],
          ].map(([feat, saas, hi]) => (
            <tr class="crow" style="border-top:1px solid rgba(144,169,85,.1);">
              <td class="ctd" style="padding:1rem 1.5rem;color:rgba(248,243,185,.8);background:rgba(19,42,19,.2);font-weight:500;">{feat}</td>
              <td class="ctd" style="padding:1rem 1.5rem;color:rgba(248,243,185,.38);background:rgba(19,42,19,.08);">{saas}</td>
              <td class="ctd ctd-good" style="padding:1rem 1.5rem;font-family:'IBM Plex Mono',monospace;font-weight:600;font-size:.825rem;color:#90A955;background:rgba(252,163,17,.03);">{hi}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

  </div>
</section>


<!-- ══════════════════════════════════════════════
     STEPS
══════════════════════════════════════════════ -->
<section style="background:#132A13;padding:7rem 1.5rem;" id="pasos">
  <div class="wrap" style="max-width:1040px;margin:0 auto;width:100%;">
    <h2 style="font-size:clamp(1.8rem,4vw,2.8rem);color:#F8F3B9;margin-bottom:3rem;">
      Lo instalas hoy.<br/>
      <span style="color:#FCA311;">Cobras mañana.</span>
    </h2>

    <div style="display:flex;flex-direction:column;max-width:680px;">
      {[
        ['01', 'Instala en minutos',   'Lo instalas en tu PC — Windows o Mac, sin complicaciones.'],
        ['02', 'Configura tu negocio', 'Configuras en 3 pasos — nombre, mesas, colores y menú. El asistente te guía.'],
        ['03', 'Agrega tu menú',       'Pon tus platillos y precios — o carga los datos de prueba para explorarlo ya.'],
        ['04', 'A vender',             'Listo. A vender. Sin contratos, sin renta, sin depender de nadie.'],
      ].map(([num, title, desc], i) => (
        <>
          <div class="scard" style="display:flex;align-items:flex-start;gap:1.75rem;background:#1e3d1e;border:1px solid rgba(144,169,85,.15);border-radius:8px;padding:1.5rem 1.75rem;">
            <span style="font-family:'IBM Plex Mono',monospace;font-weight:600;font-size:2rem;color:#FCA311;line-height:1;min-width:52px;flex-shrink:0;">{num}</span>
            <div>
              <h3 style="font-size:1rem;color:#F8F3B9;margin-bottom:.4rem;">{title}</h3>
              <p style="font-size:.875rem;color:rgba(248,243,185,.6);line-height:1.65;">{desc}</p>
            </div>
          </div>
          {i < 3 && <div style="width:1px;height:14px;background:rgba(144,169,85,.25);margin-left:3.25rem;"></div>}
        </>
      ))}
    </div>
  </div>
</section>


<!-- ══════════════════════════════════════════════
     PRIVACY
══════════════════════════════════════════════ -->
<section style="position:relative;background:#1e3d1e;padding:7rem 1.5rem;overflow:hidden;">
  <div class="divider-top"></div>
  <div style="position:absolute;right:-4rem;top:50%;transform:translateY(-50%);width:400px;height:400px;border-radius:50%;background:radial-gradient(circle, rgba(144,169,85,0.07) 0%, transparent 70%);pointer-events:none;"></div>

  <div class="wrap" style="max-width:1040px;margin:0 auto;width:100%;">
    <div class="privacy-grid" style="display:grid;gap:3rem;grid-template-columns:1fr;">

      <!-- Text -->
      <div>
        <p style="font-family:'IBM Plex Mono',monospace;font-size:.68rem;letter-spacing:.12em;text-transform:uppercase;color:#90A955;margin-bottom:1.4rem;opacity:.8;">Privacidad total</p>
        <h2 style="font-size:clamp(1.8rem,3.5vw,2.8rem);color:#F8F3B9;margin-bottom:1.4rem;">
          Tus datos no le<br/>
          pertenecen a<br/>
          <span style="color:#FCA311;">ninguna nube.</span>
        </h2>
        <p style="font-size:.975rem;color:rgba(248,243,185,.65);line-height:1.8;margin-bottom:2rem;max-width:500px;">
          Con hi-POS, toda tu información vive en tu propia máquina. Tú
          decides cuándo respaldar, cuándo migrar y qué hacer con tus
          números. Nadie más tiene acceso. Ni nosotros.
        </p>
        <ul style="list-style:none;display:flex;flex-direction:column;gap:.85rem;padding:0;">
          {[
            'Base de datos local en tu equipo',
            'Respaldos manuales con un clic',
            'Licencia vinculada a tu hardware — nadie más puede usar tu copia',
            'Sin servidores externos, sin telemetría, sin suscripciones',
          ].map(item => (
            <li style="display:flex;align-items:flex-start;gap:.75rem;color:rgba(248,243,185,.72);font-size:.9rem;line-height:1.55;">
              <svg style="color:#90A955;flex-shrink:0;margin-top:2px;" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              {item}
            </li>
          ))}
        </ul>
      </div>

      <!-- Visual -->
      <div style="display:flex;flex-direction:column;align-items:flex-start;gap:1.25rem;">
        <div>
          <div style="width:256px;height:172px;background:#132A13;border:2px solid rgba(144,169,85,.3);border-radius:10px 10px 4px 4px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:.75rem;position:relative;overflow:hidden;">
            <div style="position:absolute;inset:0;background:radial-gradient(ellipse at center, rgba(144,169,85,0.08) 0%, transparent 65%);"></div>
            <svg style="color:#90A955;position:relative;z-index:1;" width="50" height="50" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="3" y="11" width="18" height="11" rx="2"/>
              <path d="M7 11V7a5 5 0 0110 0v4"/>
              <circle cx="12" cy="16" r="1" fill="currentColor"/>
            </svg>
            <p style="font-family:'IBM Plex Mono',monospace;font-size:.72rem;color:rgba(248,243,185,.5);text-align:center;line-height:1.45;position:relative;z-index:1;">Tus datos aquí.<br/>Solo tuyos.</p>
          </div>
          <div style="width:80px;height:12px;background:rgba(144,169,85,.18);border-radius:0 0 4px 4px;margin:0 auto;"></div>
        </div>
        <div style="display:inline-flex;align-items:center;gap:.5rem;border:1px solid rgba(248,243,185,.1);color:rgba(248,243,185,.3);padding:.5rem 1rem;border-radius:4px;font-family:'IBM Plex Mono',monospace;font-size:.72rem;">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M17.5 19H9a7 7 0 01-7-7 7 7 0 017-7 7 7 0 016.98 7M18 20a4 4 0 100-8 4 4 0 000 8"/>
            <line x1="2" y1="2" x2="22" y2="22"/>
          </svg>
          Sin nube
        </div>
      </div>

    </div>
  </div>
</section>


<!-- ══════════════════════════════════════════════
     CTA FINAL
══════════════════════════════════════════════ -->
<section style="background:#132A13;padding:7rem 1.5rem;" id="demo">
  <div class="wrap" style="max-width:1040px;margin:0 auto;width:100%;">
    <div style="position:relative;background:#1a331a;border:1px solid rgba(252,163,17,.25);border-radius:14px;padding:5rem 2rem;text-align:center;overflow:hidden;">
